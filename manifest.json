{
  "manifest_version": 3,
  "name": "ESC Back Navigation",
  "version": "1.0",
  "description": "Navigate back with ESC key",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ESC Navigation",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}